# Marketing Billing Buddy — self-hosted environment.
# Copy to .env.selfhost and edit before running `docker compose --env-file .env.selfhost up -d`.

############
# Postgres
############
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=postgres
POSTGRES_PORT=54322

############
# Auth (JWT)
#
# JWT_SECRET must be at least 32 characters.
# ANON_KEY / SERVICE_ROLE_KEY are JWTs signed with JWT_SECRET. Generate fresh
# ones with the helper script: `node supabase/selfhost/scripts/generate-keys.mjs`
# (it prints all three values; paste them here).
############
JWT_SECRET=change-me-to-a-32-character-or-longer-secret
JWT_EXPIRY=3600
ANON_KEY=replace-with-generated-anon-jwt
SERVICE_ROLE_KEY=replace-with-generated-service-role-jwt

############
# URLs — what browsers (on the LAN) will hit.
# If serving from the office PC at 192.168.1.50, use that IP here.
############
API_EXTERNAL_URL=http://localhost:54321
PUBLIC_API_URL=http://localhost:54321
SITE_URL=http://localhost:8080
ADDITIONAL_REDIRECT_URLS=http://localhost:8080,http://localhost:8080/*

############
# Ports
############
KONG_HTTP_PORT=54321
STUDIO_PORT=54323
APP_PORT=8080

############
# Studio (admin dashboard) basic-auth
############
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=change-me-dashboard-password
STUDIO_DEFAULT_ORGANIZATION=Marketing Billing
STUDIO_DEFAULT_PROJECT=marketing-billing-buddy

############
# GoTrue
############
DISABLE_SIGNUP=true
MAILER_AUTOCONFIRM=true
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=Marketing Billing Buddy
